# Required
GEMINI_API_KEY=replace_with_your_key
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# Define what YES/NO should mean for the Human Presence Check function.
DECISION_QUESTION=Is there a human present in this frame?
# Default for Room Summary To Morse:
ROOM_DESCRIPTION_PROMPT=Describe the contents in the room in the most minimalistic manner such that Morse code is enough for the user to understand the scene.
# Default for Switch 1 long-press ASL translation mode:
ASL_TRANSLATION_PROMPT=Watch the full ASL signing in the video and convert it to the shortest correct English phrase possible for later Braille output.

# Camera settings
CAMERA_INDEX=0
# Optional: direct device path (recommended on Pi), e.g. /dev/video0
CAMERA_DEVICE=
# Camera backend order (comma-separated): ANY,V4L2,GSTREAMER,FFMPEG
CAMERA_BACKENDS=V4L2,ANY
FRAME_WIDTH=1280
FRAME_HEIGHT=720
VIDEO_FRAME_WIDTH=640
VIDEO_FRAME_HEIGHT=480
CAMERA_WARMUP_FRAMES=8
CAMERA_READ_ATTEMPTS=20
VIDEO_FPS=10.0
SAVE_CAPTURE=true
CAPTURE_PATH=captures/latest.jpg
VIDEO_CAPTURE_PATH=captures/latest_asl.mp4

# GPIO numbering mode
# BOARD means physical header pin numbers. BCM means GPIO numbers.
PIN_MODE=BOARD

# Canonical pin defaults live in pin_defaults.py.
# The values below are optional overrides if your wiring is different.

# Existing outputs
LED_PIN=11
MOTOR_PIN=36
# Additional LED for distance mode
AUX_LED_PIN=13

# Switches
# Assumes push button wired between GPIO pin and GND (active-low)
SWITCH_ACTIVE_LOW=true
SWITCH_DEBOUNCE_SECONDS=0.25
MODE_SWITCH_LONG_PRESS_SECONDS=2.5
# Switch 2 selection timing:
# short press  -> Room Summary To Morse
# 2-3 second press -> Distance Navigation Alert
# 3+ second press -> Human Presence Check
SELECTOR_MEDIUM_PRESS_SECONDS=2.0
SELECTOR_LONG_PRESS_SECONDS=3.0
MODE_SWITCH_PIN=29
SELECTOR_SWITCH_PIN=31

# HC-SR04 for Distance Navigation Alert
# VCC should be wired to BOARD pin 2 (5V)
HCSR04_TRIGGER_PIN=16
HCSR04_ECHO_PIN=18
HCSR04_TIMEOUT_SECONDS=0.03
DISTANCE_THRESHOLD_CM=150
DISTANCE_MIN_PERIOD_SECONDS=0.08
DISTANCE_MAX_PERIOD_SECONDS=0.80
DISTANCE_READ_INTERVAL_SECONDS=0.08
DISTANCE_LOG_INTERVAL_SECONDS=0.5

# Function scheduling
REPEAT_SAME_MORSE=true
DOT_SECONDS=0.2
MAIN_LOOP_SLEEP_SECONDS=0.03
