# Required
GEMINI_API_KEY=replace_with_your_key
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# Define what YES/NO should mean for your image analysis.
# Example: "Is there a person visible in this frame?"
DECISION_QUESTION=Is the target condition true in this frame?

# Camera settings
CAMERA_INDEX=0
# Optional: direct device path (recommended on Pi), e.g. /dev/video0
CAMERA_DEVICE=
# Camera backend order (comma-separated): ANY,V4L2,GSTREAMER,FFMPEG
CAMERA_BACKENDS=V4L2,ANY
FRAME_WIDTH=1280
FRAME_HEIGHT=720
CAMERA_WARMUP_FRAMES=8
CAMERA_READ_ATTEMPTS=20
SAVE_CAPTURE=true
CAPTURE_PATH=captures/latest.jpg

# GPIO settings
# BOARD means physical pin numbers. BCM means GPIO numbers.
PIN_MODE=BOARD
LED_PIN=16
MOTOR_PIN=13

# Morse timing (seconds)
DOT_SECONDS=0.2
